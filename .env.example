# Runtime
CRUCIBLE_ENV=local
CRUCIBLE_LOG_LEVEL=INFO

# Phase 0 provider
CRUCIBLE_PHASE0_PROVIDER=gmicloud
GMICLOUD_API_KEY=
# Alias also supported by Genblaze examples:
GMI_API_KEY=
REPLICATE_API_TOKEN=

# Backblaze B2 / S3-compatible API
B2_APPLICATION_KEY_ID=
# Alias also supported by Genblaze examples:
B2_KEY_ID=
B2_APPLICATION_KEY=
# Alias also supported by Genblaze examples:
B2_APP_KEY=
# Other common aliases also accepted:
B2_APPLICATION_KEY_VALUE=
B2_SECRET_KEY=
B2_SECRET_ACCESS_KEY=
B2_BUCKET_NAME=
B2_BUCKET_REGION=
B2_ENDPOINT_URL=
B2_OBJECT_LOCK_ENABLED=false
B2_OBJECT_LOCK_MODE=governance
B2_OBJECT_LOCK_RETENTION_DAYS=30

# Test controls
CRUCIBLE_RUN_LIVE_PROVIDER_TESTS=false

# API
CRUCIBLE_API_DRY_RUN_DEFAULT=false
CRUCIBLE_API_ALLOW_DRY_RUN=true
CRUCIBLE_MAX_PROMPT_CHARS=1200
CRUCIBLE_API_CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
